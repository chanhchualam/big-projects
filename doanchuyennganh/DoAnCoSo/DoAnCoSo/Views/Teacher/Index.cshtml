
@{
    ViewData["Title"] = "Teachers";
}

<h2>Teachers</h2>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @foreach (var teacher in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <img src="@teacher.ImageUrl" class="card-img-top" alt="@teacher.Name" style="height: 250px; object-fit: cover;" />

                <div class="card-body">
                    <h5 class="card-title">@teacher.Name</h5>
                    <p class="card-text"><strong>Gender:</strong> @teacher.Gender</p>
                    <p class="card-text"><strong>Center:</strong> @teacher.Center?.Name</p>
                </div>

                <div class="card-footer text-center">
                    <a asp-action="Display" asp-route-id="@teacher.Id" class="btn btn-primary">View Details</a>
                </div>
            </div>
        </div>
    }
</div>
