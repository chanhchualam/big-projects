@model IEnumerable<DoAnCoSo.Models.Major>
@{
    ViewData["Title"] = "Danh Sách Ngành Học";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">
                <i class="bi bi-book"></i> Danh Sách Ngành Học
            </h2>

            <!-- Search and Filter Form -->
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <form method="get" asp-action="Index" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Tìm kiếm</label>
                            <input type="text" name="keyword" class="form-control" 
                                   value="@ViewBag.Keyword" placeholder="Tên ngành, mã ngành...">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Khối thi</label>
                            <select name="examBlockId" class="form-select">
                                <option value="">Tất cả</option>
                                @foreach (var block in ViewBag.ExamBlocks as List<DoAnCoSo.Models.ExamBlock>)
                                {
                                    <option value="@block.Id" selected="@(ViewBag.ExamBlockId == block.Id)">@block.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Điểm từ</label>
                            <input type="number" name="minScore" class="form-control" 
                                   value="@ViewBag.MinScore" step="0.1" placeholder="Min">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Điểm đến</label>
                            <input type="number" name="maxScore" class="form-control" 
                                   value="@ViewBag.MaxScore" step="0.1" placeholder="Max">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Thành phố</label>
                            <select name="city" class="form-select">
                                <option value="">Tất cả</option>
                                @foreach (var city in ViewBag.Cities as List<string>)
                                {
                                    <option value="@city" selected="@(ViewBag.City == city)">@city</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-1 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-search"></i> Tìm
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Results Count -->
            <div class="mb-3">
                <p class="text-muted">Tìm thấy <strong>@Model.Count()</strong> ngành học</p>
            </div>

            <!-- Major Cards -->
            <div class="row">
                @foreach (var major in Model)
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            @if (!string.IsNullOrEmpty(major.ImageUrl))
                            {
                                <img src="@major.ImageUrl" class="card-img-top" alt="@major.Name" style="height: 200px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                                    <i class="bi bi-book text-white" style="font-size: 4rem;"></i>
                                </div>
                            }
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@major.Name</h5>
                                @if (!string.IsNullOrEmpty(major.Code))
                                {
                                    <p class="text-muted small mb-2">Mã ngành: @major.Code</p>
                                }
                                <p class="card-text flex-grow-1">
                                    @(major.Description?.Length > 100 ? major.Description.Substring(0, 100) + "..." : major.Description)
                                </p>
                                <div class="mb-2">
                                    @if (major.Duration > 0)
                                    {
                                        <span class="badge bg-info me-1">
                                            <i class="bi bi-clock"></i> @major.Duration năm
                                        </span>
                                    }
                                    @if (major.AdmissionScores.Any())
                                    {
                                        <span class="badge bg-success me-1">
                                            <i class="bi bi-star"></i> @major.AdmissionScores.Count trường
                                        </span>
                                    }
                                </div>
                                <a href="@Url.Action("Details", "Major", new { id = major.Id })" class="btn btn-primary mt-auto">
                                    <i class="bi bi-eye"></i> Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    <i class="bi bi-info-circle"></i> Không tìm thấy ngành học nào phù hợp với tiêu chí của bạn.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

