@model List<DoAnCoSo.Models.Major>
@{
    ViewData["Title"] = "So Sánh Ngành Học";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-bar-chart"></i> So Sánh Ngành Học
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> Vui lòng chọn ít nhất một ngành học để so sánh.
            <a href="@Url.Action("Index", "Major")" class="alert-link">Quay lại danh sách</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Tiêu chí</th>
                        @foreach (var major in Model)
                        {
                            <th>@major.Name</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Mã ngành</strong></td>
                        @foreach (var major in Model)
                        {
                            <td>@(major.Code ?? "-")</td>
                        }
                    </tr>
                    <tr>
                        <td><strong>Thời gian đào tạo</strong></td>
                        @foreach (var major in Model)
                        {
                            <td>@(major.Duration > 0 ? major.Duration + " năm" : "-")</td>
                        }
                    </tr>
                    <tr>
                        <td><strong>Học phí (VNĐ/năm)</strong></td>
                        @foreach (var major in Model)
                        {
                            <td>@(major.TuitionFee.HasValue ? major.TuitionFee.Value.ToString("N0") : "-")</td>
                        }
                    </tr>
                    <tr>
                        <td><strong>Số trường đào tạo</strong></td>
                        @foreach (var major in Model)
                        {
                            <td>@(major.AdmissionScores?.Count ?? 0)</td>
                        }
                    </tr>
                    <tr>
                        <td><strong>Điểm chuẩn cao nhất</strong></td>
                        @foreach (var major in Model)
                        {
                            <td>
                                @if (major.AdmissionScores?.Any() == true)
                                {
                                    <span class="badge bg-danger">@major.AdmissionScores.Max(s => s.Score)</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        }
                    </tr>
                    <tr>
                        <td><strong>Điểm chuẩn thấp nhất</strong></td>
                        @foreach (var major in Model)
                        {
                            <td>
                                @if (major.AdmissionScores?.Any() == true)
                                {
                                    <span class="badge bg-success">@major.AdmissionScores.Min(s => s.Score)</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        }
                    </tr>
                    <tr>
                        <td><strong>Chi tiết</strong></td>
                        @foreach (var major in Model)
                        {
                            <td>
                                <a href="@Url.Action("Details", "Major", new { id = major.Id })" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="mt-4">
            <a href="@Url.Action("Index", "Major")" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

