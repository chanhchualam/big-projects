@model DoAnCoSo.Models.Major
@{
    ViewData["Title"] = "Dự Đoán Tỷ Lệ Đậu - " + Model.Name;
    var probabilityData = ViewBag.ProbabilityData as List<dynamic>;
    var chartData = ViewBag.ChartData as List<dynamic>;
    var studentProfile = ViewBag.StudentProfile as DoAnCoSo.Models.StudentProfile;
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-graph-up-arrow"></i> Dự Đoán Tỷ Lệ Đậu - @Model.Name
    </h2>

    @if (studentProfile?.ExpectedScore == null)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> 
            Bạn chưa cập nhật điểm dự kiến thi THPT. 
            <a href="@Url.Action("Edit", "StudentProfile")" class="alert-link">Cập nhật điểm ngay</a> để sử dụng tính năng này.
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <!-- Student Score Info -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Điểm dự kiến của bạn</h5>
                    </div>
                    <div class="card-body">
                        <div class="display-6 text-primary fw-bold">
                            @studentProfile.ExpectedScore.Value.ToString("0.0") điểm
                        </div>
                        <p class="text-muted mb-0">Dựa trên điểm này, hệ thống sẽ tính toán khả năng đậu của bạn.</p>
                    </div>
                </div>

                <!-- Probability Results -->
                @if (probabilityData != null && probabilityData.Any())
                {
                    <div class="card shadow-sm mb-4">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">Kết Quả Dự Đoán</h5>
                        </div>
                        <div class="card-body">
                            @foreach (var item in probabilityData)
                            {
                                <div class="mb-4 p-3 border rounded">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <h6 class="mb-1">@item.universityName</h6>
                                            <span class="badge bg-info">Khối @item.examBlockCode</span>
                                        </div>
                                        <div class="text-end">
                                            <div class="badge @GetProbabilityBadgeClass((decimal)item.probability) fs-6">
                                                @item.probability% - @item.probabilityText
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row mt-3">
                                        <div class="col-md-3">
                                            <small class="text-muted">Điểm của bạn</small>
                                            <div class="fw-bold">@item.studentScore điểm</div>
                                        </div>
                                        <div class="col-md-3">
                                            <small class="text-muted">Điểm TB 3-5 năm</small>
                                            <div class="fw-bold">@item.averageScore điểm</div>
                                        </div>
                                        <div class="col-md-3">
                                            <small class="text-muted">Điểm gần nhất</small>
                                            <div class="fw-bold">@item.recentScore điểm</div>
                                        </div>
                                        <div class="col-md-3">
                                            <small class="text-muted">Phạm vi</small>
                                            <div class="fw-bold">@item.minScore - @item.maxScore điểm</div>
                                        </div>
                                    </div>

                                    <!-- Progress Bar -->
                                    <div class="mt-3">
                                        <div class="progress" style="height: 30px;">
                                            <div class="progress-bar @GetProgressBarClass((decimal)item.probability)" 
                                                 role="progressbar" 
                                                 style="width: @item.probability%"
                                                 aria-valuenow="@item.probability" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="100">
                                                <strong>@item.probability%</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> 
                        Không có đủ dữ liệu điểm chuẩn để tính toán tỷ lệ đậu cho ngành này.
                    </div>
                }

                <!-- Score Trend Chart -->
                @if (chartData != null && chartData.Any())
                {
                    <div class="card shadow-sm">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0"><i class="bi bi-bar-chart"></i> Biến Động Điểm Chuẩn</h5>
                        </div>
                        <div class="card-body">
                            <canvas id="scoreTrendChart" style="max-height: 400px;"></canvas>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <!-- Labor Market Insights -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-dark">
                        <h6 class="mb-0"><i class="bi bi-briefcase"></i> Thị Trường Lao Động</h6>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.CareerOpportunities))
                        {
                            <div class="mb-3">
                                <strong>Cơ hội việc làm:</strong>
                                <p class="mb-0">@Model.CareerOpportunities</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.AverageSalary))
                        {
                            <div class="mb-3">
                                <strong>Mức lương trung bình:</strong>
                                <p class="text-success fw-bold mb-0">@Model.AverageSalary</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.RequiredQualities))
                        {
                            <div>
                                <strong>Tố chất cần có:</strong>
                                <p class="mb-0">@Model.RequiredQualities</p>
                            </div>
                        }

                        @if (string.IsNullOrEmpty(Model.CareerOpportunities) && string.IsNullOrEmpty(Model.AverageSalary))
                        {
                            <p class="text-muted mb-0">Thông tin thị trường lao động đang được cập nhật...</p>
                        }
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h6 class="mb-0">Thao tác</h6>
                    </div>
                    <div class="card-body">
                        <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-outline-primary w-100 mb-2">
                            <i class="bi bi-arrow-left"></i> Về trang chi tiết
                        </a>
                        <a href="@Url.Action("Edit", "StudentProfile")" class="btn btn-outline-success w-100 mb-2">
                            <i class="bi bi-pencil"></i> Cập nhật điểm
                        </a>
                        <a href="@Url.Action("Index", "Major")" class="btn btn-outline-info w-100">
                            <i class="bi bi-search"></i> Tìm ngành khác
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@functions {
    string GetProbabilityBadgeClass(decimal probability)
    {
        if (probability >= 75) return "bg-success";
        if (probability >= 50) return "bg-info";
        if (probability >= 30) return "bg-warning";
        return "bg-danger";
    }

    string GetProgressBarClass(decimal probability)
    {
        if (probability >= 75) return "bg-success";
        if (probability >= 50) return "bg-info";
        if (probability >= 30) return "bg-warning";
        return "bg-danger";
    }
}

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        @if (chartData != null && chartData.Any())
        {
            <text>
            const ctx = document.getElementById('scoreTrendChart');
            if (ctx) {
                const chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(chartData));
                
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: chartData.map(d => d.year),
                        datasets: [
                            {
                                label: 'Điểm trung bình',
                                data: chartData.map(d => d.averageScore),
                                borderColor: 'rgb(75, 192, 192)',
                                backgroundColor: 'rgba(75, 192, 192, 0.2)',
                                tension: 0.4,
                                fill: true,
                                pointRadius: 5,
                                pointHoverRadius: 7
                            },
                            {
                                label: 'Điểm cao nhất',
                                data: chartData.map(d => d.maxScore),
                                borderColor: 'rgb(255, 99, 132)',
                                backgroundColor: 'rgba(255, 99, 132, 0.1)',
                                tension: 0.4,
                                borderDash: [5, 5],
                                pointRadius: 4
                            },
                            {
                                label: 'Điểm thấp nhất',
                                data: chartData.map(d => d.minScore),
                                borderColor: 'rgb(54, 162, 235)',
                                backgroundColor: 'rgba(54, 162, 235, 0.1)',
                                tension: 0.4,
                                borderDash: [5, 5],
                                pointRadius: 4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            title: {
                                display: true,
                                text: 'Xu hướng điểm chuẩn qua các năm',
                                font: {
                                    size: 16,
                                    weight: 'bold'
                                }
                            },
                            legend: {
                                display: true,
                                position: 'bottom'
                            },
                            tooltip: {
                                mode: 'index',
                                intersect: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: false,
                                title: {
                                    display: true,
                                    text: 'Điểm chuẩn',
                                    font: {
                                        weight: 'bold'
                                    }
                                },
                                grid: {
                                    color: 'rgba(0, 0, 0, 0.1)'
                                }
                            },
                            x: {
                                title: {
                                    display: true,
                                    text: 'Năm',
                                    font: {
                                        weight: 'bold'
                                    }
                                },
                                grid: {
                                    display: false
                                }
                            }
                        },
                        interaction: {
                            mode: 'nearest',
                            axis: 'x',
                            intersect: false
                        }
                    }
                });
            }
            </text>
        }
    </script>
}

