@model DoAnCoSo.Models.University
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" class="card-img-top" alt="@Model.Name" style="height: 300px; object-fit: contain; padding: 20px;">
                }
                <div class="card-body">
                    <h1 class="card-title">@Model.Name</h1>
                    @if (!string.IsNullOrEmpty(Model.Code))
                    {
                        <p class="text-muted">Mã trường: @Model.Code</p>
                    }

                    <div class="row mb-3">
                        @if (!string.IsNullOrEmpty(Model.City))
                        {
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-geo-alt"></i> Thành phố:</strong> @Model.City
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Type))
                        {
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-tag"></i> Loại trường:</strong> @Model.Type
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Address))
                        {
                            <div class="col-12 mb-2">
                                <strong><i class="bi bi-pin-map"></i> Địa chỉ:</strong> @Model.Address
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                        {
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-telephone"></i> Điện thoại:</strong> @Model.PhoneNumber
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Website))
                        {
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-globe"></i> Website:</strong> 
                                <a href="@Model.Website" target="_blank">@Model.Website</a>
                            </div>
                        }
                        @if (Model.Ranking.HasValue)
                        {
                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-trophy"></i> Xếp hạng:</strong> #@Model.Ranking
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <hr />
                        <h5>Giới thiệu</h5>
                        <p>@Html.Raw(Model.Description?.Replace("\n", "<br/>"))</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Admission Scores -->
            @if (Model.AdmissionScores != null && Model.AdmissionScores.Any())
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-graph-up"></i> Điểm Chuẩn</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Ngành</th>
                                        <th>Khối</th>
                                        <th>Điểm</th>
                                        <th>Năm</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var score in Model.AdmissionScores.OrderByDescending(s => s.Year).ThenByDescending(s => s.Score).Take(10))
                                    {
                                        <tr>
                                            <td><small>@score.Major?.Name</small></td>
                                            <td><span class="badge bg-info">@score.ExamBlock?.Code</span></td>
                                            <td><strong>@score.Score</strong></td>
                                            <td>@score.Year</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- Quick Actions -->
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h6 class="mb-0">Thao tác</h6>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Index", "Major")" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-search"></i> Tìm ngành học
                    </a>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

