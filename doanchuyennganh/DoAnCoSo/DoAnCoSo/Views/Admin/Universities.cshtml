@model IEnumerable<DoAnCoSo.Models.University>
@{
    ViewData["Title"] = "Quản Lý Trường Đại Học";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-building"></i> Quản Lý Trường Đại Học</h2>
        <a href="@Url.Action("CreateUniversity")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm Trường Mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên trường</th>
                    <th>Mã trường</th>
                    <th>Thành phố</th>
                    <th>Loại</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var university in Model)
                {
                    <tr>
                        <td>@university.Id</td>
                        <td>@university.Name</td>
                        <td>@(university.Code ?? "-")</td>
                        <td>@(university.City ?? "-")</td>
                        <td>@(university.Type ?? "-")</td>
                        <td>
                            <a href="@Url.Action("EditUniversity", new { id = university.Id })" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <form asp-action="DeleteUniversity" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa?');">
                                <input type="hidden" name="id" value="@university.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Về trang quản trị
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

