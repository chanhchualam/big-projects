@model IEnumerable<DoAnCoSo.Models.ExamBlock>
@{
    ViewData["Title"] = "Quản Lý Khối Thi";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-list-check"></i> Quản Lý Khối Thi</h2>
        <a href="@Url.Action("CreateExamBlock")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm Khối Thi Mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Mã khối</th>
                    <th>Tên khối</th>
                    <th>Các môn thi</th>
                    <th>Mô tả</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var block in Model)
                {
                    <tr>
                        <td>@block.Id</td>
                        <td><span class="badge bg-primary">@block.Code</span></td>
                        <td>@block.Name</td>
                        <td>@(block.Subjects ?? "-")</td>
                        <td>@(block.Description ?? "-")</td>
                        <td>
                            <a href="@Url.Action("EditExamBlock", new { id = block.Id })" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <form asp-action="DeleteExamBlock" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa?');">
                                <input type="hidden" name="id" value="@block.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Về trang quản trị
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

