@model IEnumerable<DoAnCoSo.Models.Major>
@{
    ViewData["Title"] = "Quản Lý Ngành Học";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-book"></i> Quản Lý Ngành Học</h2>
        <a href="@Url.Action("CreateMajor")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm Ngành Mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên ngành</th>
                    <th>Mã ngành</th>
                    <th>Thời gian</th>
                    <th>Học phí</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var major in Model)
                {
                    <tr>
                        <td>@major.Id</td>
                        <td>@major.Name</td>
                        <td>@(major.Code ?? "-")</td>
                        <td>@major.Duration năm</td>
                        <td>@(major.TuitionFee.HasValue ? major.TuitionFee.Value.ToString("N0") + " VNĐ" : "-")</td>
                        <td>
                            <a href="@Url.Action("EditMajor", new { id = major.Id })" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <a href="@Url.Action("DeleteMajor", new { id = major.Id })" class="btn btn-sm btn-danger" onclick="return confirm('Bạn có chắc muốn xóa?');">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Về trang quản trị
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

