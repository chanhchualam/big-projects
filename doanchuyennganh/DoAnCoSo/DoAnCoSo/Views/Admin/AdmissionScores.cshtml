@model IEnumerable<DoAnCoSo.Models.AdmissionScore>
@{
    ViewData["Title"] = "Quản Lý Điểm Chuẩn";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-graph-up"></i> Quản Lý Điểm Chuẩn</h2>
        <a href="@Url.Action("CreateAdmissionScore")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm Điểm Chuẩn Mới
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Ngành học</th>
                    <th>Trường</th>
                    <th>Khối</th>
                    <th>Năm</th>
                    <th>Điểm</th>
                    <th>Chỉ tiêu</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var score in Model)
                {
                    <tr>
                        <td>@score.Id</td>
                        <td>@(score.Major?.Name ?? "-")</td>
                        <td>@(score.University?.Name ?? "-")</td>
                        <td><span class="badge bg-info">@(score.ExamBlock?.Code ?? "-")</span></td>
                        <td>@score.Year</td>
                        <td><strong>@score.Score</strong></td>
                        <td>@(score.Quota?.ToString() ?? "-")</td>
                        <td>
                            <a href="@Url.Action("EditAdmissionScore", new { id = score.Id })" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <form asp-action="DeleteAdmissionScore" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa?');">
                                <input type="hidden" name="id" value="@score.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index")" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Về trang quản trị
        </a>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

