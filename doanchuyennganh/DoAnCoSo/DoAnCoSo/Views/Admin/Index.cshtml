@{
    ViewData["Title"] = "Trang Quản Trị";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-gear"></i> Trang Quản Trị Hệ Thống
    </h2>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-book text-primary" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Quản lý Ngành học</h5>
                    <p class="text-muted">Thêm, sửa, xóa ngành học</p>
                    <a href="@Url.Action("Majors")" class="btn btn-primary">Quản lý</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-building text-success" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Quản lý Trường ĐH</h5>
                    <p class="text-muted">Thêm, sửa, xóa trường đại học</p>
                    <a href="@Url.Action("Universities")" class="btn btn-success">Quản lý</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-list-check text-info" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Quản lý Khối thi</h5>
                    <p class="text-muted">Thêm, sửa, xóa khối thi</p>
                    <a href="@Url.Action("ExamBlocks")" class="btn btn-info">Quản lý</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-graph-up text-warning" style="font-size: 3rem;"></i>
                    <h5 class="mt-3">Quản lý Điểm chuẩn</h5>
                    <p class="text-muted">Thêm, sửa, xóa điểm chuẩn</p>
                    <a href="@Url.Action("AdmissionScores")" class="btn btn-warning">Quản lý</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

