@{
    ViewData["Title"] = "Trang Chủ - Hệ Thống Tư Vấn Ngành Học Đại Học";
}

<div class="hero-section bg-primary text-white py-5 mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold mb-4">
                    <i class="bi bi-mortarboard"></i> Tìm Ngành Học Phù Hợp Với Bạn
                </h1>
                <p class="lead mb-4">
                    Hệ thống tư vấn ngành học đại học thông minh, giúp học sinh THPT định hướng nghề nghiệp và chọn ngành học phù hợp nhất.
                </p>
                <div class="d-flex gap-3">
                    <a href="@Url.Action("Index", "Major")" class="btn btn-light btn-lg">
                        <i class="bi bi-search"></i> Tìm Ngành Học
                    </a>
                    <a href="@Url.Action("Index", "Chat")" class="btn btn-outline-light btn-lg">
                        <i class="bi bi-chat-dots"></i> Chat AI
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <i class="bi bi-graph-up-arrow" style="font-size: 15rem; opacity: 0.3;"></i>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <!-- Features Section -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-5">
            <h2 class="mb-3">Tại Sao Chọn Chúng Tôi?</h2>
            <p class="text-muted">Hệ thống tích hợp nhiều tính năng thông minh để hỗ trợ bạn tốt nhất</p>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-robot text-primary" style="font-size: 3rem;"></i>
                </div>
                <h5>Chat AI Thông Minh</h5>
                <p class="text-muted">Tư vấn 24/7 với trợ lý AI, trả lời mọi thắc mắc về ngành học, điểm chuẩn và cơ hội việc làm.</p>
                <a href="@Url.Action("Index", "Chat")" class="btn btn-outline-primary">Thử ngay</a>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-search text-success" style="font-size: 3rem;"></i>
                </div>
                <h5>Tìm Kiếm Thông Minh</h5>
                <p class="text-muted">Tìm kiếm và lọc ngành học theo khối thi, điểm chuẩn, thành phố và nhiều tiêu chí khác.</p>
                <a href="@Url.Action("Index", "Major")" class="btn btn-outline-success">Tìm kiếm</a>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-clipboard-data text-info" style="font-size: 3rem;"></i>
                </div>
                <h5>Điểm Chuẩn Cập Nhật</h5>
                <p class="text-muted">Dữ liệu điểm chuẩn đầy đủ, cập nhật từ các trường đại học hàng đầu Việt Nam.</p>
                <a href="@Url.Action("Index", "Major")" class="btn btn-outline-info">Xem điểm chuẩn</a>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-heart text-danger" style="font-size: 3rem;"></i>
                </div>
                <h5>Lưu Ngành Yêu Thích</h5>
                <p class="text-muted">Lưu lại các ngành học quan tâm để theo dõi và so sánh dễ dàng.</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="@Url.Action("Favorites", "StudentProfile")" class="btn btn-outline-danger">Xem đã lưu</a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account", new { area = "Identity" })" class="btn btn-outline-danger">Đăng nhập</a>
                }
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-person-circle text-warning" style="font-size: 3rem;"></i>
                </div>
                <h5>Hồ Sơ Cá Nhân</h5>
                <p class="text-muted">Quản lý thông tin học tập, điểm số và mục tiêu nghề nghiệp của bạn.</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="@Url.Action("Index", "StudentProfile")" class="btn btn-outline-warning">Xem hồ sơ</a>
                }
                else
                {
                    <a href="@Url.Action("Login", "Account", new { area = "Identity" })" class="btn btn-outline-warning">Đăng nhập</a>
                }
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-bar-chart text-secondary" style="font-size: 3rem;"></i>
                </div>
                <h5>So Sánh Ngành Học</h5>
                <p class="text-muted">So sánh chi tiết các ngành học để đưa ra quyết định đúng đắn nhất.</p>
                <a href="@Url.Action("Index", "Major")" class="btn btn-outline-secondary">So sánh</a>
            </div>
        </div>
    </div>

    <!-- Statistics Section -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-body text-center py-5">
                    <h3 class="mb-4">Thống Kê</h3>
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-primary fw-bold">100+</div>
                            <p class="text-muted">Ngành học</p>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-success fw-bold">50+</div>
                            <p class="text-muted">Trường đại học</p>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-info fw-bold">1000+</div>
                            <p class="text-muted">Điểm chuẩn</p>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="display-6 text-warning fw-bold">24/7</div>
                            <p class="text-muted">Hỗ trợ AI</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CTA Section -->
    @if (User.Identity?.IsAuthenticated != true)
    {
        <div class="row mb-5">
            <div class="col-12">
                <div class="card bg-light shadow-sm">
                    <div class="card-body text-center py-5">
                        <h3 class="mb-3">Sẵn Sàng Bắt Đầu?</h3>
                        <p class="lead text-muted mb-4">Đăng ký tài khoản ngay để sử dụng đầy đủ các tính năng</p>
                        <a href="@Url.Action("Register", "Account", new { area = "Identity" })" class="btn btn-primary btn-lg me-2">
                            <i class="bi bi-person-plus"></i> Đăng Ký
                        </a>
                        <a href="@Url.Action("Login", "Account", new { area = "Identity" })" class="btn btn-outline-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right"></i> Đăng Nhập
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .hero-section {
            border-radius: 10px;
            margin-top: 20px;
        }
    </style>
}
