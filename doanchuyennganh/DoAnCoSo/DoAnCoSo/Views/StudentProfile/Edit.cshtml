@model DoAnCoSo.Models.StudentProfile
@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container mt-4">
    <h2 class="mb-4">
        <i class="bi bi-pencil-square"></i> Chỉnh Sửa Hồ Sơ
    </h2>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="HighSchoolName" class="form-label">Trường THPT</label>
                                <input asp-for="HighSchoolName" class="form-control" />
                                <span asp-validation-for="HighSchoolName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="City" class="form-label">Tỉnh/Thành phố</label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />
                        <h5 class="mb-3">Điểm trung bình các môn (điểm thang 10)</h5>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="MathScore" class="form-label">Toán</label>
                                <input asp-for="MathScore" class="form-control" type="number" step="0.1" min="0" max="10" />
                                <span asp-validation-for="MathScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="PhysicsScore" class="form-label">Vật lý</label>
                                <input asp-for="PhysicsScore" class="form-control" type="number" step="0.1" min="0" max="10" />
                                <span asp-validation-for="PhysicsScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ChemistryScore" class="form-label">Hóa học</label>
                                <input asp-for="ChemistryScore" class="form-control" type="number" step="0.1" min="0" max="10" />
                                <span asp-validation-for="ChemistryScore" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="LiteratureScore" class="form-label">Ngữ văn</label>
                                <input asp-for="LiteratureScore" class="form-control" type="number" step="0.1" min="0" max="10" />
                                <span asp-validation-for="LiteratureScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="HistoryScore" class="form-label">Lịch sử</label>
                                <input asp-for="HistoryScore" class="form-control" type="number" step="0.1" min="0" max="10" />
                                <span asp-validation-for="HistoryScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="GeographyScore" class="form-label">Địa lý</label>
                                <input asp-for="GeographyScore" class="form-control" type="number" step="0.1" min="0" max="10" />
                                <span asp-validation-for="GeographyScore" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="EnglishScore" class="form-label">Tiếng Anh</label>
                                <input asp-for="EnglishScore" class="form-control" type="number" step="0.1" min="0" max="10" />
                                <span asp-validation-for="EnglishScore" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ExpectedScore" class="form-label">Điểm dự kiến thi THPT</label>
                                <input asp-for="ExpectedScore" class="form-control" type="number" step="0.1" min="0" max="30" />
                                <span asp-validation-for="ExpectedScore" class="text-danger"></span>
                            </div>
                        </div>

                        <hr />

                        <div class="mb-3">
                            <label asp-for="Interests" class="form-label">Sở thích</label>
                            <textarea asp-for="Interests" class="form-control" rows="3" placeholder="Ví dụ: Công nghệ, Khoa học, Nghệ thuật..."></textarea>
                            <span asp-validation-for="Interests" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CareerGoal" class="form-label">Mục tiêu nghề nghiệp</label>
                            <textarea asp-for="CareerGoal" class="form-control" rows="3" placeholder="Mô tả mục tiêu nghề nghiệp của bạn..."></textarea>
                            <span asp-validation-for="CareerGoal" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}

