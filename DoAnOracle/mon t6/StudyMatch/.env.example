# Oracle Database Configuration
DB_PROVIDER=oracle

ORACLE_USER=user
ORACLE_PASSWORD=password
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=xe

# Notes:
# - Oracle XE 18c/21c commonly uses service name: XEPDB1
# - Older Oracle XE may use: XE
# Set ORACLE_SERVICE to match what you see in SQL Developer.

# Optional: set a full SQLAlchemy URI directly (overrides ORACLE_* above)
# ORACLE_URI=oracle+oracledb://user:password@localhost:1521/?service_name=XEPDB1

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# App behavior
# For Oracle, prefer creating schema via database/oracle/studymatch_oracle_full.sql
# and keep AUTO_CREATE_TABLES=false to avoid creating quoted tables like "DanhGia".
AUTO_CREATE_TABLES=false

# Seed demo users when empty (test_student / 123456). Set false if you imported sample data via SQL.
SEED_DATABASE=false

# Application Settings
APP_NAME=StudyMatch
APP_VERSION=1.0.0
