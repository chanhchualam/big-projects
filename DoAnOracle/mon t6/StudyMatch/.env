# Select DB provider: oracle | sqlite
DB_PROVIDER=oracle

# Oracle Database Configuration
# Fill these with your real credentials
ORACLE_USER=STUDYMATCH
ORACLE_PASSWORD=StudyMatch@123
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE=XEPDB1

# Optional: set a full SQLAlchemy URI directly (overrides ORACLE_* above)
# ORACLE_URI=oracle+oracledb://user:password@localhost:1521/?service_name=XEPDB1

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# App behavior
SEED_DATABASE=false

AUTO_CREATE_TABLES=false

